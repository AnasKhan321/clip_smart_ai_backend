# LLM provider selection
# gemini uses Google's Gemini API. This is the current default for production.
LLM_PROVIDER=gemini

# OpenRouter mode
OPENROUTER_API_KEY=your_openrouter_key
ANALYZER_MODEL=anthropic/claude-sonnet-4-5
HOOK_GEN_MODEL=google/gemini-2.5-flash-lite

# Google Gemini mode
# Do not commit real keys. Set this in your deployment secrets.
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CLOUD_PROJECT=goviral-455119
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-3.5-flash

# Optional: use a separate Gemini key/model for hook text generation.
# If unset, hook generation uses GOOGLE_API_KEY + GEMINI_MODEL.
GEMINI_HOOK_GEN_API_KEY=
GEMINI_HOOK_GEN_MODEL=gemini-3.5-flash

# Analyzer output budget
ANALYZER_MAX_TOKENS=4096
ANALYZER_CHUNK_WORKERS=3
